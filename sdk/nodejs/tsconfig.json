{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "cksCluster.ts",
        "config/index.ts",
        "config/vars.ts",
        "getCksCluster.ts",
        "getNetworkingVpc.ts",
        "getObjectStorageBucketPolicyDocument.ts",
        "index.ts",
        "networkingVpc.ts",
        "objectStorageBucket.ts",
        "objectStorageBucketLifecycleConfiguration.ts",
        "objectStorageBucketPolicy.ts",
        "objectStorageBucketSettings.ts",
        "objectStorageBucketVersioning.ts",
        "objectStorageOrganizationAccessPolicy.ts",
        "provider.ts",
        "region/index.ts",
        "types/enums/index.ts",
        "types/enums/region/index.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
